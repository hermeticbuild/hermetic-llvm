+static uint8_t checkedSchedClassEntryCount(
+    size_t Count, StringRef EntryKind, const CodeGenProcModel &ProcModel,
+    const CodeGenSchedClass &SchedClass) {
+  if (Count > std::numeric_limits<uint8_t>::max())
