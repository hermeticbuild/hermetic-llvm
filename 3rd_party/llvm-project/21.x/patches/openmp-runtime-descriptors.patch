+} // namespace RuntimeFunctions
+
+namespace RuntimeAttributes {
+
+enum class SetKind : uint8_t {
+#define OMP_ATTRS_SET(Name, ...) Name,
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  Last
+};
+
+static_assert(sizeof(SetKind) == 1,
+              "OpenMP runtime attribute set kinds must remain compact");
+
+#define OMP_ATTRS_SET(Name, ...) constexpr SetKind Name = SetKind::Name;
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+
+constexpr size_t AttributeSetCount = 0
+#define OMP_PARAM_ATTRS(...) (std::array{EmptyAttrs, __VA_ARGS__})
+#define OMP_RTL_ATTRS(Enum, FnAttrSet, RetAttrSet, ArgAttrSets)                \
+  +2 + ArgAttrSets.size()
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+    ;
+
+constexpr auto AttributeSets = [] {
+  std::array<SetKind, AttributeSetCount> Result{};
+  size_t Offset = 0;
+#define OMP_PARAM_ATTRS(...) (std::array{EmptyAttrs, __VA_ARGS__})
+#define OMP_RTL_ATTRS(Enum, FnAttrSet, RetAttrSet, ArgAttrSets)                \
+  {                                                                            \
+    Result[Offset++] = FnAttrSet;                                              \
+    Result[Offset++] = RetAttrSet;                                             \
+    constexpr auto ArgumentAttributes = ArgAttrSets;                           \
+    for (SetKind Kind : ArgumentAttributes)                                    \
+      Result[Offset++] = Kind;                                                 \
+  }
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  return Result;
+}();
+
+constexpr uint16_t NoAttributes = std::numeric_limits<uint16_t>::max();
+
+struct Descriptor {
+  uint16_t AttributeOffset;
+  uint8_t ArgumentCount;
+};
+
+static_assert(sizeof(Descriptor) == 4,
+              "OpenMP runtime attribute descriptors must remain compact");
+
+constexpr auto Descriptors = [] {
+  std::array<Descriptor,
+             static_cast<size_t>(omp::RuntimeFunction::OMPRTL___last)>
+      Result{};
+  for (Descriptor &D : Result)
+    D.AttributeOffset = NoAttributes;
+
+  uint16_t AttributeOffset = 0;
+#define OMP_PARAM_ATTRS(...) (std::array{EmptyAttrs, __VA_ARGS__})
+#define OMP_RTL_ATTRS(Enum, FnAttrSet, RetAttrSet, ArgAttrSets)                \
+  {                                                                            \
+    constexpr auto ArgumentAttributes = ArgAttrSets;                           \
+    static_assert(ArgumentAttributes.size() - 1 <=                             \
+                  std::numeric_limits<uint8_t>::max());                        \
+    Result[static_cast<size_t>(omp::RuntimeFunction::Enum)] = {                \
+        AttributeOffset, static_cast<uint8_t>(ArgumentAttributes.size() - 1)}; \
+    AttributeOffset = static_cast<uint16_t>(AttributeOffset + 2 +              \
+                                            ArgumentAttributes.size());        \
+  }
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  return Result;
+}();
+
+static_assert(AttributeSets.size() < NoAttributes);
+
+static AttributeSet getAttributeSet(Module &M, LLVMContext &Ctx, SetKind Kind) {
+  switch (Kind) {
+#define OMP_ATTRS_SET(Name, AttrSet)                                           \
+  case SetKind::Name:                                                          \
+    return AttrSet;
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  case SetKind::Last:
+    break;
+  }
+  llvm_unreachable("invalid OpenMP runtime attribute set kind");
+}
