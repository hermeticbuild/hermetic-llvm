+namespace {
+
+namespace RuntimeFunctions {
+
+enum class TypeKind : uint8_t {
+#define OMP_TYPE(Name, ...) Name,
+#define OMP_ARRAY_TYPE(Name, ...) Name##Ty, Name##PtrTy,
+#define OMP_FUNCTION_TYPE(Name, ...) Name, Name##Ptr,
+#define OMP_STRUCT_TYPE(Name, ...) Name, Name##Ptr,
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  Last
+};
+
+static_assert(sizeof(TypeKind) == 1,
+              "OpenMP runtime type kinds must remain compact");
+
+#define OMP_TYPE(Name, ...) constexpr TypeKind Name = TypeKind::Name;
+#define OMP_ARRAY_TYPE(Name, ...)                                              \
+  constexpr TypeKind Name##Ty = TypeKind::Name##Ty;                            \
+  constexpr TypeKind Name##PtrTy = TypeKind::Name##PtrTy;
+#define OMP_FUNCTION_TYPE(Name, ...)                                           \
+  constexpr TypeKind Name = TypeKind::Name;                                    \
+  constexpr TypeKind Name##Ptr = TypeKind::Name##Ptr;
+#define OMP_STRUCT_TYPE(Name, ...)                                             \
+  constexpr TypeKind Name = TypeKind::Name;                                    \
+  constexpr TypeKind Name##Ptr = TypeKind::Name##Ptr;
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+
+struct NameTable {
+#define OMP_RTL(Enum, Str, ...) char Enum[sizeof(Str)];
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+};
+
+constexpr NameTable Names = {
+#define OMP_RTL(Enum, Str, ...) Str,
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+};
+
+constexpr size_t TypeCount = 0
+#define OMP_RTL(Enum, Str, IsVarArg, ReturnType, ...)                          \
+  +std::array{ReturnType, __VA_ARGS__}.size()
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+    ;
+
+constexpr auto Types = [] {
+  std::array<TypeKind, TypeCount> Result{};
+  size_t Offset = 0;
+#define OMP_RTL(Enum, Str, IsVarArg, ReturnType, ...)                          \
+  {                                                                            \
+    constexpr auto Entry = std::array{ReturnType, __VA_ARGS__};                \
+    for (TypeKind Kind : Entry)                                                \
+      Result[Offset++] = Kind;                                                 \
+  }
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  return Result;
+}();
+
+struct Descriptor {
+  uint16_t NameOffset;
+  uint16_t TypeOffset;
+  uint8_t ArgumentCount;
+  uint8_t IsVarArg;
+};
+
+static_assert(sizeof(Descriptor) == 6,
+              "OpenMP runtime function descriptors must remain compact");
+
+constexpr auto Descriptors = [] {
+  std::array<Descriptor,
+             static_cast<size_t>(omp::RuntimeFunction::OMPRTL___last) + 1>
+      Result{};
+  uint16_t TypeOffset = 0;
+#define OMP_RTL(Enum, Str, IsVarArg, ReturnType, ...)                          \
+  {                                                                            \
+    constexpr auto Entry = std::array{ReturnType, __VA_ARGS__};                \
+    static_assert(Entry.size() - 1 <= std::numeric_limits<uint8_t>::max());    \
+    Result[static_cast<size_t>(omp::RuntimeFunction::Enum)] = {                \
+        static_cast<uint16_t>(offsetof(NameTable, Enum)), TypeOffset,          \
+        static_cast<uint8_t>(Entry.size() - 1), IsVarArg};                     \
+    TypeOffset = static_cast<uint16_t>(TypeOffset + Entry.size());             \
+  }
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  return Result;
+}();
+
+static_assert(Types.size() <= std::numeric_limits<uint16_t>::max());
+static_assert(sizeof(Names) <= std::numeric_limits<uint16_t>::max());
+
+static Type *getType(const OpenMPIRBuilder &Builder, TypeKind Kind) {
+  switch (Kind) {
+#define OMP_TYPE(Name, ...)                                                    \
+  case TypeKind::Name:                                                         \
+    return Builder.Name;
+#define OMP_ARRAY_TYPE(Name, ...)                                              \
+  case TypeKind::Name##Ty:                                                     \
+    return Builder.Name##Ty;                                                   \
+  case TypeKind::Name##PtrTy:                                                  \
+    return Builder.Name##PtrTy;
+#define OMP_FUNCTION_TYPE(Name, ...)                                           \
+  case TypeKind::Name:                                                         \
+    return Builder.Name;                                                       \
+  case TypeKind::Name##Ptr:                                                    \
+    return Builder.Name##Ptr;
+#define OMP_STRUCT_TYPE(Name, ...)                                             \
+  case TypeKind::Name:                                                         \
+    return Builder.Name;                                                       \
+  case TypeKind::Name##Ptr:                                                    \
+    return Builder.Name##Ptr;
+#include "llvm/Frontend/OpenMP/OMPKinds.def"
+  case TypeKind::Last:
+    break;
+  }
+  llvm_unreachable("invalid OpenMP runtime type kind");
+}
