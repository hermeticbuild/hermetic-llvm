        "exception_ptr.h": "bits/exception_ptr.h",
        "hash_bytes.h": "bits/hash_bytes.h",
        "nested_exception.h": "bits/nested_exception.h",
    },
    root_paths = [
        "libstdc++-v3/include/std",
