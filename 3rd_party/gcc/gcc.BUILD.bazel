    allow_overwrites = True,
    replace_prefixes = {
        "atomic_lockfree_defines.h": "bits/atomic_lockfree_defines.h",
        "cxxabi_forced.h": "bits/cxxabi_forced.h",
        "cxxabi_init_exception.h": "bits/cxxabi_init_exception.h",
        "exception.h": "bits/exception.h",
