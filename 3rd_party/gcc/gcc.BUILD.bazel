filegroup(
    name = "libstdcxx_structured_headers",
    # These installed subtrees are large enough to keep as globs. The excludes
    # preserve the Makefile.am boundary between installed headers, generated
    # templates, and maintainer-only inputs.
    srcs = glob(
        [
            "libstdc++-v3/include/backward/**",
            "libstdc++-v3/include/bits/**",
            "libstdc++-v3/include/debug/**",
            "libstdc++-v3/include/decimal/**",
            "libstdc++-v3/include/experimental/**",
            "libstdc++-v3/include/ext/**",
            "libstdc++-v3/include/parallel/**",
            "libstdc++-v3/include/pstl/**",
            "libstdc++-v3/include/tr1/**",
            "libstdc++-v3/include/tr2/**",
        ],
        exclude = [
            "**/Makefile.*",
            "**/.editorconfig",
            "**/*.def",
            "**/*.in",
            "**/*.tpl",
            "libstdc++-v3/include/bits/c++config",
        ],
    ),
)

