        ":libsupcxx_private_headers",
        ":libsupcxx_unwind_h",
    ],
    copts = LIBSTDCXX_BUILD_COPTS,
    implementation_deps = ["@llvm//runtimes/libstdcxx:build_headers"],
    includes = [
        "libgcc",
        "libstdc++-v3/libsupc++",
    ],
)

