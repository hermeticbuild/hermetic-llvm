    name = "libsupcxx_unwind_h",
    src = "libgcc/unwind-generic.h",
    out = "libgcc/unwind.h",
)

expand_template(
    name = "libsupcxx_tinfo_windows_cc",
    out = "libsupcxx_generated/tinfo_windows.cc",
    substitutions = {
        """bool
std::type_info::__equal (const std::type_info& arg) const _GLIBCXX_NOEXCEPT
__attribute__((alias("_ZNKSt9type_infoeqERKS_")));""": """bool
std::type_info::__equal (const std::type_info& arg) const _GLIBCXX_NOEXCEPT
{
  return operator== (arg);
}""",
    },
    template = "libstdc++-v3/libsupc++/tinfo.cc",
)

